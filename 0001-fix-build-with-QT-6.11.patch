From 0b0efdfc68f212908a62b13bde6239517af8e0a9 Mon Sep 17 00:00:00 2001
From: CNflysky <cnflysky@qq.com>
Date: Wed, 6 May 2026 14:52:52 +0800
Subject: [PATCH] fix build with QT 6.11+

---
 CMakeLists.txt                    | 1 +
 pv/views/tabular_decoder/view.cpp | 6 ++++--
 2 files changed, 5 insertions(+), 2 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index e0520e0..c1ebf33 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -565,6 +565,7 @@ add_definitions(-DQT_NO_KEYWORDS)
 add_definitions(-D__STDC_LIMIT_MACROS)
 add_definitions(-Wall -Wextra)
 add_definitions(${REQUIRED_STD_CXX_FLAGS})
+add_definitions(-DQT_NO_USE_NODISCARD_FILE_OPEN)
 
 add_definitions(-DBOOST_MATH_DISABLE_FLOAT128=1)
 if(WIN32)
diff --git a/pv/views/tabular_decoder/view.cpp b/pv/views/tabular_decoder/view.cpp
index c1d7429..9539778 100644
--- a/pv/views/tabular_decoder/view.cpp
+++ b/pv/views/tabular_decoder/view.cpp
@@ -106,17 +106,19 @@ bool CustomFilterProxyModel::filterAcceptsRow(int sourceRow,
 void CustomFilterProxyModel::set_sample_range(uint64_t start_sample,
 	uint64_t end_sample)
 {
+	beginFilterChange();
 	range_start_sample_ = start_sample;
 	range_end_sample_ = end_sample;
 
-	invalidateFilter();
+	endFilterChange(QSortFilterProxyModel::Direction::Rows);
 }
 
 void CustomFilterProxyModel::enable_range_filtering(bool value)
 {
+	beginFilterChange();
 	range_filtering_enabled_ = value;
 
-	invalidateFilter();
+	endFilterChange(QSortFilterProxyModel::Direction::Rows);
 }
 
 
